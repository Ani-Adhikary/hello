import XCTest
@testable import YourAppModuleName  // Replace with your actual app module name

// MARK: - Mock Pasteboard
protocol Pasteboard {
    var string: String? { get set }
}

class MockPasteboard: Pasteboard {
    var string: String?
}

// MARK: - Test Class
final class CVVViewModelTests: XCTestCase {
    
    // MARK: - getAdditionalPublicDataToPasteboard Tests
    
    func testGetAdditionalPublicDataToPasteboard_nameOnCard() {
        let viewModel = CVVViewModel()
        let result = viewModel.getAdditionalPublicDataToPasteboard(key: .nameOnCard)
        XCTAssertEqual(result, "Wes William Anderson")
    }
    
    func testGetAdditionalPublicDataToPasteboard_cardNumber() {
        let viewModel = CVVViewModel()
        let result = viewModel.getAdditionalPublicDataToPasteboard(key: .cardNumber)
        XCTAssertEqual(result, "1234 1234 1234 1212")
    }
    
    // MARK: - getAdditionalPublicDataTitleToDisplay Tests
    
    func testGetTitleToDisplay_nameOnCard() {
        let viewModel = CVVViewModel()
        let expected = localized.localizedString(for: "cardDetailCopyNameTitle") // Replace with actual key if different
        let result = viewModel.getAdditionalPublicDataTitleToDisplay(key: .nameOnCard)
        XCTAssertEqual(result, expected)
    }
    
    func testGetTitleToDisplay_cardNumber() {
        let viewModel = CVVViewModel()
        let expected = localized.localizedString(for: "CardDetailCopyNumberTitle") // Replace with actual key if different
        let result = viewModel.getAdditionalPublicDataTitleToDisplay(key: .cardNumber)
        XCTAssertEqual(result, expected)
    }
    
    // MARK: - clickCopyButton Tests
    
    func testClickCopyButton_copiesNameOnCardToPasteboard() {
        let viewModel = CVVViewModel()
        let mockPasteboard = MockPasteboard()
        viewModel.pasteboard = mockPasteboard

        viewModel.clickCopyButton(key: .nameOnCard)

        XCTAssertEqual(mockPasteboard.string, "Wes William Anderson")
    }
    
    func testClickCopyButton_copiesCardNumberToPasteboard() {
        let viewModel = CVVViewModel()
        let mockPasteboard = MockPasteboard()
        viewModel.pasteboard = mockPasteboard

        viewModel.clickCopyButton(key: .cardNumber)

        XCTAssertEqual(mockPasteboard.string, "1234 1234 1234 1212")
    }
}

