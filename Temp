func countdownText() -> some View {
    let countMsg = viewModel.getCVVCountdownMessageTitle()
    let second = viewModel.getCVVCountdownSecondTitle()
    let seconds = viewModel.getCVVCountdownSecondsTitle()

    let isSingular = countdown == 1
    let boldText = Text("\(countdown) \(isSingular ? second : seconds) ")
        .themedFont(token: .semanticTypographyContentCaptionLoud)
    let normalText = Text(countMsg)
        .themedFont(token: .semanticTypographyContentBodyNormal)

    return (boldText + normalText)
        .foregroundColor(style.base.colors.secondaryText)
        .padding(.horizontal, style.base.dimensions.paddingHorizontal)
        .transition(.opacity)
        .accessibilityIdentifier("cvvCountdown")
}
