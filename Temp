var body: some View {
    let viewModel = CardDetailViewModel()

    ZStack(alignment: .top) {
        GeometryReader { geo in
            VStack(spacing: 0) {
                ScrollView {
                    mainView(viewModel: viewModel)
                }
                .frame(height: geo.size.height)  // fill entire height
            }
            .frame(width: geo.size.width, height: geo.size.height)
        }
    }
    .snackBar(
        isShowing: $isCopyAlertShow,
        snackBarDuration: .short,
        reset: true,
        snackBar: SnackBar(content: copyTitle, mode: .success)
    )
}
