

struct TileCardSecurityView: View {
    @EnvironmentObject private var themeManager: ThemeManager

    let primaryInfoText: String
    let secondaryText: String

    @State private var isCVVVisible: Bool = false
    @State private var countdown: Int = 12
    @State private var timer: Timer?

    var style: Tile.Style {
        Tile.Style(themeManager)
    }

    var body: some View {
        VStack(alignment: .leading) {
            HStack(alignment: .top) {
                VStack(alignment: .leading, spacing: 0) {
                    Text(primaryInfoText)
                        .themedFont(token: .semanticTypographyContentFootnoteNormal)
                        .foregroundColor(style.colors.primaryText)
                        .accessibilityIdentifier("primaryText")
                        .accessibilityLabel("Cardholder name: \(primaryInfoText)")

                    Text(isCVVVisible ? secondaryText : "•••")
                        .themedFont(token: .semanticTypographyContentCaptionLoud)
                        .foregroundColor(style.colors.secondaryText)
                        .transition(.opacity)
                        .accessibilityIdentifier("secondaryText")
                        .accessibilityLabel(isCVVVisible ? "CVV: \(secondaryText)" : "CVV is hidden")
                }

                Spacer()

                Button(action: toggleCVVVisibility) {
                    HStack(spacing: 4) {
                        Text(isCVVVisible ? "Hide" : "View")
                            .font(.footnote)
                            .textCase(.none)
                        Image(systemName: isCVVVisible ? "eye.slash" : "eye")
                            .resizable()
                            .frame(width: 16, height: 12)
                            .accessibilityHidden(true)
                    }
                    .foregroundColor(.black)
                    .padding(6)
                }
                .accessibilityIdentifier("viewButton")
                .accessibilityLabel(isCVVVisible ? "Hide CVV" : "View CVV")
                .accessibilityHint("Double tap to \(isCVVVisible ? "hide" : "view") the CVV securely")
            }
            .padding(.horizontal, style.dimensions.paddingHorizontal)

            // Optional Countdown Section
            if isCVVVisible {
                Text("\(countdown) seconds until CVV is hidden")
                    .font(.caption)
                    .foregroundColor(.gray)
                    .padding(.horizontal, style.dimensions.paddingHorizontal)
                    .transition(.opacity)
                    .accessibilityIdentifier("cvvCountdown")
                    .accessibilityLabel("\(countdown) seconds remaining until CVV is hidden automatically")
            }

            Divider()
                .padding(.top, 8)
                .accessibilityHidden(true)
        }
        .padding(.top, style.dimensions.paddingVertical)
        .background(Color.cyan)
        .cornerRadius(12)
        .accessibilityElement(children: .contain)
        .accessibilityLabel("Card Information. \(primaryInfoText). CVV \(isCVVVisible ? secondaryText : "hidden")")
        .accessibilityIdentifier("cvvTile")
        .onDisappear {
            stopTimer()
        }
    }

    private func toggleCVVVisibility() {
        withAnimation {
            isCVVVisible.toggle()
            if isCVVVisible {
                startTimer()
            } else {
                stopTimer()
            }
        }
    }

    private func startTimer() {
        countdown = 12
        timer?.invalidate()
        timer = Timer.scheduledTimer(withTimeInterval: 1.0, repeats: true) { _ in
            if countdown > 1 {
                countdown -= 1
            } else {
                withAnimation {
                    isCVVVisible = false
                }
                stopTimer()
            }
        }
    }

    private func stopTimer() {
        timer?.invalidate()
        timer = nil
    }
}



