func body(content: Content) -> some View {
    GeometryReader { geometry in
        ZStack(alignment: .top) {
            content
                .frame(width: geometry.size.width, height: geometry.size.height) // Fill the whole screen

            if isShowing {
                snackBarView()
                    .padding(.top, 10) // spacing from top
            }
        }
    }
}
