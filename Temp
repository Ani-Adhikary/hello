import XCTest
@testable import YourAppModule

final class CVVViewModelTests: XCTestCase {

    class MockPasteboard: Pasteboard {
        var string: String?
    }

    func testCopy_nameOnCard_shouldCopyToPasteboard() {
        let mock = MockPasteboard()
        let viewModel = CVVViewModel(pasteboard: mock)

        viewModel.clickCopyButton(key: .nameOnCard)

        XCTAssertEqual(mock.string, "Wes William Anderson")
    }

    func testCopy_cardNumber_shouldCopyToPasteboard() {
        let mock = MockPasteboard()
        let viewModel = CVVViewModel(pasteboard: mock)

        viewModel.clickCopyButton(key: .cardNumber)

        XCTAssertEqual(mock.string, "1234 1234 1234 1212")
    }

    func testCopy_empty_shouldNotCopy() {
        class EmptyReturnViewModel: CVVViewModel {
            override func getAdditionalPublicDataToPasteboard(key: AdditionalInfoKey) -> String {
                return ""
            }
        }

        let mock = MockPasteboard()
        let viewModel = EmptyReturnViewModel(pasteboard: mock)

        viewModel.clickCopyButton(key: .nameOnCard)

        XCTAssertNil(mock.string)
    }
}
