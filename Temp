
@ViewBuilder
private func makeBalanceView(viewModel: BalancePanelViewModel) -> some View {
    Group {
        if isIpad {
            HStack {
                balanceItemView(
                    title: viewModel.balancePanelCurrentBalance,
                    amount: viewModel.currentBalance,
                    alignment: .leading
                )
                balanceItemView(
                    title: viewModel.balancePanelAvailableCredit,
                    amount: viewModel.availableCredit,
                    alignment: .trailing
                )
            }
        } else {
            VStack(alignment: .leading, spacing: 8) {
                balanceItemView(
                    title: viewModel.balancePanelCurrentBalance,
                    amount: viewModel.currentBalance,
                    alignment: .leading
                )
                balanceItemView(
                    title: viewModel.balancePanelAvailableCredit,
                    amount: viewModel.availableCredit,
                    alignment: sizeCategory >= .accessibilityLarge ? .leading : .trailing
                )
            }
        }
    }
}


