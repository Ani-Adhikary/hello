var body: some View {
    GeometryReader { geometry in
        VStack(spacing: 0) {
            panelMainView(viewModel: CardDetailViewModel())
            Spacer() // Pushes the main view to the top
        }
        .frame(width: geometry.size.width, height: geometry.size.height)
        .snackBar(
            isShowing: $isCopyAlertShow,
            snackBarDuration: .short,
            reset: true,
            content: {
                SnackBar(content: copyTitle, mode: .success)
                    .frame(maxWidth: .infinity)
            }
        )
    }
}
