import XCTest
@testable import YourAppModule

final class CVVAccessibilityTests: XCTestCase {
    func testAccessibilityHintConstants() {
        XCTAssertEqual(CVVAccessibility.actionPrefix, "Double tap to")
        XCTAssertEqual(CVVAccessibility.actionView, "view")
        XCTAssertEqual(CVVAccessibility.actionHide, "hide")
        XCTAssertEqual(CVVAccessibility.actionSuffix, "the CVV securely")
    }
}



func testFinalAccessibilityHint() {
    let isCVVVisible = true
    let expected = "\(CVVAccessibility.actionPrefix) \(CVVAccessibility.actionHide) \(CVVAccessibility.actionSuffix)"
    XCTAssertEqual(expected, "Double tap to hide the CVV securely")
}

