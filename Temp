var body: some View {
    ZStack {
        Color.clear // This forces the ZStack to expand full-screen

        panelMainView(viewModel: CardDetailViewModel())
    }
    .edgesIgnoringSafeArea(.all) // Ensure the stack covers top area
    .snackBar(
        isShowing: $isCopyAlertShow,
        snackBarDuration: .short,
        reset: true,
        content: {
            SnackBar(content: copyTitle, mode: .success)
                .frame(maxWidth: .infinity)
        }
    )
}
