var body: some View {
    let viewModel = CardDetailViewModel()

    VStack {
        Spacer(minLength: 0) // push content to top

        panelMainView(viewModel: viewModel)
            .background(
                GeometryReader { proxy in
                    Color.clear.preference(key: ViewHeightKey.self, value: proxy.size.height)
                }
            )

        Spacer() // allows ZStack height to match screen
    }
    .frame(maxWidth: .infinity, maxHeight: .infinity) // force full screen
    .background(Color.clear)
    .snackBar(
        isShowing: $isCopyAlertShow,
        snackBarDuration: .short,
        reset: true,
        content: {
            SnackBar(content: copyTitle, mode: .success)
                .frame(maxWidth: .infinity)
        }
    )
}
