func filterUpcomingPanelAllowingZeroStatementBalance() {
    let tmpArray = currentIndexPanelTypeArray.filter { panelType in
        if panelType == .upcomingPayments,
           let field = viewStore.cardsHubConfiguration?.upcomingPaymentPanelConfig?.paymentAmountExtractField {

            // Show if statementBalance exists (regardless of amount value)
            let statementBalanceExists = viewStore.creditAccountDetail?.creditCardStatementBalance?.amount != nil

            // Show only if currentAmountDue is > 0
            let currentAmountDueIsPositive = viewStore.creditAccountDetail?.creditCardCurrentAmountDue?.amount.isGreaterThanZero() ?? false

            let result = field.lowercased() == Constants.paymentTileUKExtraFieldValue.lowercased() ?
                statementBalanceExists :
                currentAmountDueIsPositive

            return result
        } else {
            return true
        }
    }

    currentIndexPanelTypeArray = tmpArray
}
