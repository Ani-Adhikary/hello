@ViewBuilder
private func balanceItemView(title: String, amount: String, alignment: Alignment) -> some View {
    makeAmountView(viewModel: viewModel, title: title, amount: amount, alignment: alignment, style: style)
        .lineLimit(1)
        .layoutPriority(1)
        .frame(maxWidth: .infinity, alignment: alignment)
        .accessibilityElement(children: .ignore)
        .accessibilityLabel(announceCorrectAmount(prefix: title, amount: amount))
}



