import XCTest
import SwiftUI
import ViewInspector
@testable import YourAppModule

final class CVVCountdownViewTests: XCTestCase {

    class MockCVVViewModel: CVVViewModel {
        override func getCVVCountdownMessageTitle() -> String {
            "until CVV is hidden"
        }

        override func getCVVCountdownSecondTitle() -> String {
            "second"
        }

        override func getCVVCountdownSecondsTitle() -> String {
            "seconds"
        }
    }

    func testCVVCountdownView_displaysCorrectText() throws {
        let view = CVVCountdownView(countdown: 1, viewModel: MockCVVViewModel())
        let hStack = try view.inspect().hStack()

        let firstText = try hStack.text(0).string()
        let secondText = try hStack.text(1).string()

        XCTAssertEqual(firstText, "1 second ")
        XCTAssertEqual(secondText, "until CVV is hidden")
    }

    func testAccessibilityLabel() throws {
        let view = CVVCountdownView(countdown: 3, viewModel: MockCVVViewModel())
        let label = try view.inspect().accessibilityLabel().string()

        XCTAssertEqual(label, "3 seconds until CVV is hidden")
    }
}
